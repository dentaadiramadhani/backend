{
  "name": "event-management-backend",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "npx prisma generate --schema src/prisma/schema.prisma",
    "dev": "ts-node-dev --respawn src/server.ts",
    "build": "npx prisma generate --schema src/prisma/schema.prisma && tsc",
    "start": "node dist/server.js",
    "db:generate": "npx prisma generate --schema src/prisma/schema.prisma",
    "db:migrate": "npx prisma migrate dev --schema src/prisma/schema.prisma",
    "db:push": "npx prisma db push --schema src/prisma/schema.prisma",
    "db:seed": "ts-node src/prisma/seed.ts"
  },
  "prisma": {
    "schema": "src/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "prisma": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.5"
  }
}